  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_FILE = SAO_Aincrad.exe
  TARGET_IMPLIB = libSAO_Aincrad.dll.a
  TARGET_PDB = SAO_Aincrad.exe.dbg


